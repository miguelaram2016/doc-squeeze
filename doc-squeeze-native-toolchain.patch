 import { NextRequest, NextResponse } from 'next/server';
+import { promises as fs } from 'fs';
+import os from 'os';
+import path from 'path';
+import { spawn } from 'child_process';
+
+export const runtime = 'nodejs';
+
+type CompressionLevel = 'low' | 'medium' | 'high';
+
+function runCommand(command: string, args: string[]) {
+  return new Promise<void>((resolve, reject) => {
+    const child = spawn(command, args, { stdio: ['ignore', 'pipe', 'pipe'] });
+    let stderr = '';
+
+    child.stderr.on('data', (chunk) => {
+      stderr += chunk.toString();
+    });
+
+    child.on('error', (error) => {
+      reject(error);
+    });
+
+    child.on('close', (code) => {
+      if (code === 0) {
+        resolve();
+        return;
+      }
+      reject(new Error(stderr || `${command} exited with code ${code}`));
+    });
+  });
+}
+
+async function firstAvailableCommand(candidates: string[]) {
+  for (const command of candidates) {
+    try {
+      await runCommand(command, ['--version']);
+      return command;
+    } catch {
+      // continue
+    }
+  }
+  return null;
+}
+
+async function compressPdf({
+  inputPath,
+  outputPath,
+  level,
+}: {
+  inputPath: string;
+  outputPath: string;
+  level: CompressionLevel;
+}) {
+  const qpdf = await firstAvailableCommand(['qpdf']);
+  const gs = await firstAvailableCommand(['gs', 'gswin64c', 'gswin32c']);
+
+  if (!qpdf) {
+    throw new Error('qpdf is not installed or not available on PATH');
+  }
+
+  const optimizedPath = path.join(path.dirname(outputPath), 'optimized.pdf');
+
+  await runCommand(qpdf, [
+    '--object-streams=generate',
+    '--recompress-flate',
+    '--compression-level=9',
+    '--optimize-images',
+    inputPath,
+    optimizedPath,
+  ]);
+
+  if (level === 'low') {
+    await fs.copyFile(optimizedPath, outputPath);
+    return;
+  }
+
+  if (!gs) {
+    throw new Error('Ghostscript is not installed or not available on PATH');
+  }
+
+  const pdfSetting = level === 'high' ? '/ebook' : '/printer';
+  const colorResolution = level === 'high' ? '110' : '150';
+  const grayResolution = level === 'high' ? '110' : '150';
+  const monoResolution = level === 'high' ? '200' : '300';
+
+  await runCommand(gs, [
+    '-sDEVICE=pdfwrite',
+    '-dCompatibilityLevel=1.6',
+    '-dNOPAUSE',
+    '-dBATCH',
+    '-dQUIET',
+    `-dPDFSETTINGS=${pdfSetting}`,
+    '-dDetectDuplicateImages=true',
+    '-dCompressFonts=true',
+    '-dSubsetFonts=true',
+    '-dDownsampleColorImages=true',
+    '-dColorImageDownsampleType=/Bicubic',
+    `-dColorImageResolution=${colorResolution}`,
+    '-dDownsampleGrayImages=true',
+    '-dGrayImageDownsampleType=/Bicubic',
+    `-dGrayImageResolution=${grayResolution}`,
+    '-dDownsampleMonoImages=true',
+    '-dMonoImageDownsampleType=/Subsample',
+    `-dMonoImageResolution=${monoResolution}`,
+    `-sOutputFile=${outputPath}`,
+    optimizedPath,
+  ]);
+}

